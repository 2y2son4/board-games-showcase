{
  "name": "board-games-showcase",
  "version": "0.0.0",
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "serve": "ng serve --open",
    "build": "ng build",
    "move-files": "mv ./docs/browser/* ./docs/ && rm -rf ./docs/browser",
    "build:prod": "ng build --configuration production",
    "deploy": "pnpm run build:prod && pnpm run move-files",
    "watch": "ng build --watch --configuration development",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lighthouse": "pnpm dlx unlighthouse --site https://2y2son4.github.io/board-games-showcase/"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "20.3.15",
    "@angular/cdk": "20.2.2",
    "@angular/common": "20.3.15",
    "@angular/compiler": "20.3.15",
    "@angular/core": "20.3.15",
    "@angular/forms": "20.3.15",
    "@angular/material": "20.2.2",
    "@angular/platform-browser": "20.3.15",
    "@angular/platform-browser-dynamic": "20.3.15",
    "@angular/router": "20.3.15",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.27",
    "jest": "^30.0.0",
    "jest-preset-angular": "^16.1.2",
    "jspdf": "^4.0.0",
    "prettier": "^3.2.5",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "uninstall": "^0.0.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.0.1",
    "@angular/cli": "^20.3.13",
    "@angular/compiler-cli": "20.3.15",
    "jest-environment-jsdom": "^30.3.0",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "qs": "6.14.1"
  },
  "jest": {
    "preset": "jest-preset-angular",
    "setupFilesAfterEnv": [
      "<rootDir>/src/setup.jest.ts"
    ],
    "testPathIgnorePatterns": [
      "<rootDir>/node_modules",
      "<rootDir>/dist"
    ],
    "globals": {
      "transform": {
        "tsconfig": [
          "ts-jest",
          {
            "tsconfig": "<rootDir>/tsconfig.spec.json",
            "stringifyContentPathRegex": "\\.html$"
          }
        ]
      }
    }
  }
}
